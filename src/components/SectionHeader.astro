---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  centered?: boolean;
  light?: boolean;
}
const { eyebrow, title, subtitle, centered = false, light = false } = Astro.props;
---

<div class={centered ? 'text-center max-w-2xl mx-auto' : 'max-w-2xl'}>
  {eyebrow && (
    <p class={`text-xs font-semibold uppercase tracking-widest mb-2 ${light ? 'text-ceylon-gold-400' : 'text-ceylon-green-600'}`}>
      {eyebrow}
    </p>
  )}
  <h2 class={`font-serif font-bold text-3xl sm:text-4xl text-balance ${light ? 'text-white' : 'text-gray-900'}`}>
    {title}
  </h2>
  {subtitle && (
    <p class={`mt-4 text-base sm:text-lg leading-relaxed ${light ? 'text-ceylon-green-200' : 'text-gray-500'}`}>
      {subtitle}
    </p>
  )}
</div>
