---
interface Props {
  title: string;
  description: string;
  buttonText: string;
  buttonHref: string;
  disclaimer?: string;
  variant?: 'hotel' | 'tour' | 'flight' | 'insurance';
}
const {
  title,
  description,
  buttonText,
  buttonHref,
  disclaimer = 'This post contains affiliate links. We earn a small commission at no extra cost to you.',
  variant = 'hotel',
} = Astro.props;

const icons: Record<string, string> = {
  hotel: '🏨',
  tour: '🗺️',
  flight: '✈️',
  insurance: '🛡️',
};
---

<div class="not-prose bg-gradient-to-br from-ceylon-gold-50 to-ceylon-green-50 border border-ceylon-gold-200 rounded-2xl p-6 my-10 shadow-sm">
  <div class="flex items-start gap-4">
    <div class="w-12 h-12 bg-ceylon-gold-100 rounded-xl flex items-center justify-center flex-shrink-0 text-2xl">
      {icons[variant]}
    </div>
    <div class="flex-1">
      <h4 class="font-serif font-bold text-gray-900 text-lg mb-1 leading-snug">{title}</h4>
      <p class="text-gray-600 text-sm leading-relaxed mb-4">{description}</p>
      <a
        href={buttonHref}
        target="_blank"
        rel="noopener noreferrer sponsored"
        class="inline-flex items-center gap-2 bg-ceylon-green-700 hover:bg-ceylon-green-800 text-white font-semibold px-6 py-3 rounded-xl text-sm transition-colors shadow-sm"
      >
        {buttonText}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
    </div>
  </div>
  <p class="text-xs text-gray-400 mt-5 border-t border-ceylon-gold-200 pt-3">{disclaimer}</p>
</div>
