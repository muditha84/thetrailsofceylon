---
interface Props { currentHref: string; }
const { currentHref } = Astro.props;

const allPosts = [
  { href: '/blog/2-weeks-in-sri-lanka-itinerary',    image: '/images/scenic-train.jpg',        title: 'The Perfect 2-Week Sri Lanka Itinerary',                    category: 'Itineraries'    },
  { href: '/blog/best-beaches-sri-lanka',             image: '/images/mirissa-beach.jpg',       title: "Sri Lanka's 10 Best Beaches",                               category: 'Beaches'        },
  { href: '/blog/sri-lanka-budget-travel',            image: '/images/colombo.jpg',             title: 'Sri Lanka on a Budget: How to Travel Cheap',                category: 'Budget Travel'  },
  { href: '/blog/ella-rock-hike',                     image: '/images/ella.jpg',                title: 'Hiking Ella Rock: A Complete Guide',                         category: 'Hiking'         },
  { href: '/blog/sri-lanka-food-guide',               image: '/images/cooking-classes.jpg',     title: 'Sri Lankan Food: What to Eat & Where',                      category: 'Food & Drink'   },
  { href: '/blog/best-time-visit-sri-lanka',          image: '/images/heroes/hero-hills.jpg',   title: 'Best Time to Visit Sri Lanka (Month by Month)',              category: 'Planning'       },
  { href: '/blog/sigiriya-tips',                      image: '/images/sigiriya.jpg',            title: '10 Essential Tips for Visiting Sigiriya',                   category: 'Cultural Sites' },
  { href: '/blog/sigiriya-rock-fortress-guide',       image: '/images/sigiriya.jpg',            title: 'Sigiriya Rock Fortress: The Complete Visitor Guide',         category: 'Cultural Sites' },
  { href: '/blog/ella-travel-guide',                  image: '/images/ella.jpg',                title: "Ella Travel Guide: Hill Country Village",                    category: 'Destinations'   },
  { href: '/blog/adams-peak-hiking-guide',            image: '/images/adams-peak.jpg',          title: "Adam's Peak Hiking Guide: The Sacred Climb",                category: 'Hiking'         },
  { href: '/blog/hikkaduwa-travel-guide',             image: '/images/hikkaduwa.jpg',           title: 'Hikkaduwa Travel Guide',                                    category: 'Destinations'   },
  { href: '/blog/kalpitiya-kitesurfing',              image: '/images/kalpitiya.jpg',           title: "Kalpitiya Kitesurfing: Sri Lanka's Kite Capital",           category: 'Adventure'      },
  { href: '/blog/pigeon-island-snorkelling',          image: '/images/pigeon-island.jpg',       title: "Pigeon Island: Sri Lanka's Best Snorkelling",               category: 'Nature'         },
  { href: '/blog/colombo-city-guide',                 image: '/images/colombo.jpg',             title: 'Colombo City Guide: See, Do and Eat',                       category: 'Cities'         },
  { href: '/blog/sri-lanka-waterfalls',               image: '/images/ravana-falls.jpg',        title: "Sri Lanka's Most Spectacular Waterfalls",                   category: 'Nature'         },
  { href: '/blog/turtle-watching-sri-lanka',          image: '/images/turtle-watching.jpg',     title: 'Sea Turtle Watching in Sri Lanka',                          category: 'Wildlife'       },
  { href: '/blog/sri-lanka-honeymoon-guide',          image: '/images/heroes/hero-beach.jpg',   title: 'Sri Lanka Honeymoon Guide: Romantic Escapes',               category: 'Planning'       },
  { href: '/blog/sri-lanka-family-travel',            image: '/images/pinnawala.jpg',           title: 'Sri Lanka with Kids: Family Travel Guide',                  category: 'Planning'       },
  { href: '/blog/sri-lanka-photography-guide',        image: '/images/scenic-train.jpg',        title: 'Sri Lanka Photography Guide: Best Spots & Tips',            category: 'Photography'    },
];

// Current post category
const currentPost = allPosts.find(p => p.href === currentHref);
const currentCategory = currentPost?.category;

// Prefer same category, then fill from others, max 3
const sameCategory = allPosts.filter(p => p.href !== currentHref && p.category === currentCategory);
const others = allPosts.filter(p => p.href !== currentHref && p.category !== currentCategory);
const related = [...sameCategory, ...others].slice(0, 3);
---

{related.length > 0 && (
  <div class="max-w-4xl mx-auto px-4 sm:px-6 mt-12 mb-0">
    <h2 class="font-serif font-bold text-gray-900 text-2xl mb-6">Related Articles</h2>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
      {related.map(post => (
        <a href={post.href} class="group block bg-white border border-gray-100 rounded-xl overflow-hidden hover:shadow-md transition-all duration-200">
          <div class="aspect-[16/9] overflow-hidden">
            <img
              src={post.image}
              alt={post.title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
              width="400"
              height="225"
            />
          </div>
          <div class="p-4">
            <span class="text-ceylon-green-600 text-xs font-semibold uppercase tracking-wide">{post.category}</span>
            <h3 class="font-serif font-bold text-gray-900 text-sm mt-1 leading-snug group-hover:text-ceylon-green-700 transition-colors line-clamp-2">{post.title}</h3>
          </div>
        </a>
      ))}
    </div>
  </div>
)}
