---
const currentYear = new Date().getFullYear();
---

<footer class="bg-ceylon-green-900 text-white">
  <!-- Main footer -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">

      <!-- Brand -->
      <div class="lg:col-span-1">
        <a href="/" class="inline-flex items-center gap-3 mb-4">
          <div class="w-10 h-10 rounded-full bg-ceylon-gold-500 flex items-center justify-center">
            <span class="text-white font-serif font-bold">TC</span>
          </div>
          <div>
            <span class="block font-serif font-bold text-white text-lg leading-none">The Trails of Ceylon</span>
            <span class="block text-ceylon-gold-400 text-xs tracking-widest uppercase">Sri Lanka Travel</span>
          </div>
        </a>
        <p class="text-ceylon-green-200 text-sm leading-relaxed mt-4">
          Your trusted guide to exploring the wonder island of Sri Lanka — from misty highlands to golden beaches.
        </p>
        <div class="flex gap-3 mt-6">
          <a href="https://instagram.com/thetrailsofceylon" target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-full bg-ceylon-green-700 hover:bg-ceylon-gold-500 flex items-center justify-center transition-colors" aria-label="Instagram">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </a>
          <a href="https://pinterest.com/thetrailsofceylon" target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-full bg-ceylon-green-700 hover:bg-ceylon-gold-500 flex items-center justify-center transition-colors" aria-label="Pinterest">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.627 0-12 5.373-12 12 0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
          </a>
          <a href="https://facebook.com/thetrailsofceylon" target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-full bg-ceylon-green-700 hover:bg-ceylon-gold-500 flex items-center justify-center transition-colors" aria-label="Facebook">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
        </div>
      </div>

      <!-- Explore -->
      <div>
        <h3 class="font-serif font-semibold text-white text-lg mb-5">Explore Sri Lanka</h3>
        <ul class="space-y-2.5">
          {[
            { href: '/places', label: 'Places to Visit' },
            { href: '/places/sigiriya', label: 'Sigiriya Rock' },
            { href: '/places/galle', label: 'Galle Fort' },
            { href: '/places/ella', label: 'Ella' },
            { href: '/places/kandy', label: 'Kandy' },
            { href: '/places/yala', label: 'Yala National Park' },
          ].map(link => (
            <li>
              <a href={link.href} class="text-ceylon-green-300 hover:text-ceylon-gold-400 text-sm transition-colors">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Activities -->
      <div>
        <h3 class="font-serif font-semibold text-white text-lg mb-5">Things to Do</h3>
        <ul class="space-y-2.5">
          {[
            { href: '/things-to-do', label: 'All Activities' },
            { href: '/things-to-do/whale-watching', label: 'Whale Watching' },
            { href: '/things-to-do/tea-plantation-tours', label: 'Tea Plantation Tours' },
            { href: '/things-to-do/surfing', label: 'Surfing' },
            { href: '/things-to-do/wildlife-safaris', label: 'Wildlife Safaris' },
            { href: '/things-to-do/train-rides', label: 'Scenic Train Rides' },
          ].map(link => (
            <li>
              <a href={link.href} class="text-ceylon-green-300 hover:text-ceylon-gold-400 text-sm transition-colors">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h3 class="font-serif font-semibold text-white text-lg mb-5">Travel Resources</h3>
        <ul class="space-y-2.5">
          {[
            { href: '/guides', label: 'Travel Guides' },
            { href: '/guides/sri-lanka-itinerary-2-weeks', label: '2-Week Itinerary' },
            { href: '/guides/best-time-to-visit', label: 'Best Time to Visit' },
            { href: '/blog', label: 'Travel Blog' },
            { href: '/about', label: 'About Us' },
            { href: '/contact', label: 'Contact' },
          ].map(link => (
            <li>
              <a href={link.href} class="text-ceylon-green-300 hover:text-ceylon-gold-400 text-sm transition-colors">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Newsletter -->
    <div class="mt-14 pt-10 border-t border-ceylon-green-700">
      <div class="max-w-xl mx-auto text-center">
        <h3 class="font-serif font-bold text-white text-2xl mb-2">Get Sri Lanka Travel Tips</h3>
        <p class="text-ceylon-green-300 text-sm mb-6">Join thousands of travellers. No spam, just the best of Ceylon in your inbox.</p>
        <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto" action="#" method="POST">
          <input
            type="email"
            name="email"
            placeholder="Your email address"
            required
            class="flex-1 px-4 py-3 rounded-lg bg-ceylon-green-800 border border-ceylon-green-600 text-white placeholder:text-ceylon-green-400 focus:outline-none focus:border-ceylon-gold-400 text-sm"
          />
          <button type="submit" class="bg-ceylon-gold-500 hover:bg-ceylon-gold-400 text-white font-semibold px-6 py-3 rounded-lg text-sm transition-colors whitespace-nowrap">
            Subscribe Free
          </button>
        </form>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-ceylon-green-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-ceylon-green-400 text-xs">
        &copy; {currentYear} The Trails of Ceylon. All rights reserved.
      </p>
      <div class="flex gap-5">
        <a href="/privacy" class="text-ceylon-green-400 hover:text-ceylon-gold-400 text-xs transition-colors">Privacy Policy</a>
        <a href="/disclaimer" class="text-ceylon-green-400 hover:text-ceylon-gold-400 text-xs transition-colors">Affiliate Disclaimer</a>
        <a href="/sitemap-index.xml" class="text-ceylon-green-400 hover:text-ceylon-gold-400 text-xs transition-colors">Sitemap</a>
      </div>
    </div>
  </div>
</footer>
