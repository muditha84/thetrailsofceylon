---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact | The Trails of Ceylon"
  description="Get in touch with The Trails of Ceylon — we'd love to hear from you."
>
  <section class="py-20 bg-ceylon-green-900 relative overflow-hidden">
    <div class="absolute inset-0 opacity-20">
      <img src="/images/ella.webp" alt="" class="w-full h-full object-cover object-center" loading="eager" width="800" height="600" style="object-fit:cover;" />
    </div>
    <div class="relative z-10 max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <h1 class="font-serif font-black text-white text-5xl sm:text-6xl">Contact Us</h1>
      <p class="text-ceylon-green-200 text-xl mt-4">We'd love to hear from you</p>
    </div>
  </section>

  <section class="py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <div class="grid md:grid-cols-2 gap-12 items-start">

        <!-- Info -->
        <div>
          <h2 class="font-serif font-bold text-gray-900 text-2xl mb-4">Get In Touch</h2>
          <p class="text-gray-600 mb-6 leading-relaxed">
            Have a question about Sri Lanka? Want to collaborate? Found an error in one of our guides? We're always happy to hear from fellow travellers.
          </p>
          <div class="space-y-4">
            <div class="flex items-start gap-3">
              <span class="text-2xl flex-shrink-0">📧</span>
              <div>
                <p class="text-xs font-semibold uppercase tracking-wider text-gray-400">Email</p>
                <p class="text-gray-700 font-medium">Use the form below to get in touch</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-2xl flex-shrink-0">⏱️</span>
              <div>
                <p class="text-xs font-semibold uppercase tracking-wider text-gray-400">Response time</p>
                <p class="text-gray-700 font-medium">Within 48 hours</p>
              </div>
            </div>
          </div>

          <div class="mt-8 bg-ceylon-green-50 rounded-2xl p-5">
            <h3 class="font-semibold text-gray-800 mb-2">Work with us</h3>
            <p class="text-gray-600 text-sm">
              We're open to partnerships with ethical tourism companies, accommodation providers and travel brands that align with our values. Please reach out with your proposal.
            </p>
          </div>
        </div>

        <!-- Form -->
        <form
          name="contact"
          method="POST"
          data-netlify="true"
          data-netlify-honeypot="bot-field"
          action="/contact-success/"
          class="bg-white border border-gray-200 rounded-2xl p-6 sm:p-8 shadow-sm space-y-5"
        >
          <input type="hidden" name="form-name" value="contact" />
          <p class="hidden" style="display:none"><label>Don't fill this out: <input name="bot-field" /></label></p>

          <div>
            <label for="name" class="block text-sm font-medium text-gray-700 mb-1.5">Your Name</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:outline-none focus:ring-2 focus:ring-ceylon-green-500 focus:border-transparent text-sm"
              placeholder="Jane Smith"
            />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-gray-700 mb-1.5">Email Address</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:outline-none focus:ring-2 focus:ring-ceylon-green-500 focus:border-transparent text-sm"
              placeholder="jane@example.com"
            />
          </div>
          <div>
            <label for="subject" class="block text-sm font-medium text-gray-700 mb-1.5">Subject</label>
            <select
              id="subject"
              name="subject"
              class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:outline-none focus:ring-2 focus:ring-ceylon-green-500 focus:border-transparent text-sm bg-white"
            >
              <option>General Enquiry</option>
              <option>Travel Question</option>
              <option>Partnership / Collaboration</option>
              <option>Press / Media</option>
              <option>Feedback</option>
            </select>
          </div>
          <div>
            <label for="message" class="block text-sm font-medium text-gray-700 mb-1.5">Message</label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:outline-none focus:ring-2 focus:ring-ceylon-green-500 focus:border-transparent text-sm resize-none"
              placeholder="Tell us how we can help..."
            ></textarea>
          </div>
          <button
            type="submit"
            class="w-full bg-ceylon-green-700 hover:bg-ceylon-green-800 text-white font-semibold py-3.5 rounded-xl transition-colors text-sm"
          >
            Send Message
          </button>
          <p class="text-xs text-gray-400 text-center">We reply to every message within 48 hours.</p>
        </form>

      </div>
    </div>
  </section>
</BaseLayout>
