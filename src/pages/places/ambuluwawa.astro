            ))}
          </div>
          <a href="https://www.booking.com/searchresults.html?ss=Kandy+Sri+Lanka" target="_blank" rel="noopener noreferrer sponsored" class="book-btn mt-4 block text-center">Find Hotels Nearby</a>
        </div>
