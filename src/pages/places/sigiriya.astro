              { label: 'Opening Hours', value: '6:00am – 5:30pm daily' },
              { label: 'Entry Fee', value: 'USD $30 adults' },
              { label: 'Best Months', value: 'Jan–Apr & Jul–Sep' },
              { label: 'Difficulty', value: 'Moderate (1,200 steps)' },
