        </div>

        <div class="bg-white border border-gray-100 rounded-2xl p-5 shadow-sm">
          <h3 class="font-serif font-bold text-gray-900 text-lg mb-4">More in Cultural Triangle</h3>
          <div class="space-y-3">
            {[
              { href: '/places/polonnaruwa', label: 'Polonnaruwa' },
              { href: '/places/anuradhapura', label: 'Anuradhapura' },
              { href: '/places/kandy', label: 'Kandy' },
