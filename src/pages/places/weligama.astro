          <a href="/" class="hover:text-white">Home</a><span>/</span>
          <a href="/places" class="hover:text-white">Places</a><span>/</span>
          <a href="/places/south-coast" class="hover:text-white">South Coast</a><span>/</span>
          <span class="text-white">Weligama</span>
