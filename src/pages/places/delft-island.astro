          <dl class="grid grid-cols-2 gap-x-4 gap-y-2 text-sm">
            {[["Also Known As","Neduntheevu"],["Distance from Jaffna","35km by ferry"],["Ferry From","Kurikaduwan pier"],["Best For","Off-beat, ruins, wild horses"],["Days Needed","Full day"],["Population","~5,000 (Tamil fishing community)"]].map(([k, v]) => (
