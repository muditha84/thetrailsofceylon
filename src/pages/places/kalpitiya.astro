          <dl class="grid grid-cols-2 gap-x-4 gap-y-2 text-sm">
            {[["Province","North Western Province"],["Distance from Colombo","155km (3.5 hrs)"],["Best For","Kitesurfing, dolphins, solitude"],["Kite Season","May–October (SW wind)"],["Days Needed","2–5 days"],["Lagoon Size","40km sheltered strip"]].map(([k, v]) => (
