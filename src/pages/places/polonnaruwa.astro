    <img src="/images/polonnaruwa.webp" alt="Gal Vihara rock carvings, Polonnaruwa, Sri Lanka" class="w-full h-full object-cover" style="object-fit:cover;" fetchpriority="high" width="800" height="600" />
    <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>
    <div class="absolute bottom-0 left-0 right-0 p-8">
      <div class="max-w-4xl mx-auto">
        <nav class="flex items-center gap-2 text-white/70 text-xs mb-3" aria-label="Breadcrumb">
          <a href="/" class="hover:text-white">Home</a><span>/</span>
          <a href="/places" class="hover:text-white">Places</a><span>/</span>
          <a href="/places/cultural-triangle" class="hover:text-white">Cultural Triangle</a><span>/</span>
          <span class="text-white">Polonnaruwa</span>
        </nav>
        <h1 class="font-serif font-black text-white text-4xl sm:text-5xl">Polonnaruwa</h1>
        <p class="text-white/80 mt-2">North Central Province &bull; UNESCO World Heritage Site &bull; Medieval Capital</p>
