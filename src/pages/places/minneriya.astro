          <dl class="grid grid-cols-2 gap-x-4 gap-y-2 text-sm">
            {[['Province','North Central'],['Gathering Season','July–October (peak Aug–Sep)'],['Elephants','Up to 300 at once'],['Best For','The Elephant Gathering'],['From Sigiriya','30km (30 min)'],['Entry Fee','~USD 25']].map(([k,v])=>(<><dt class="font-semibold text-gray-700">{k}</dt><dd class="text-gray-600">{v}</dd></>))}
