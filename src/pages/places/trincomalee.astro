            {[['Province','Eastern Province'],['Best Season','May–September'],['Best For','Snorkelling, beaches, temples'],['Budget','LKR 3,000–15,000/night'],['Days Needed','2–3 days'],['From Colombo','~7–8 hours']].map(([k,v])=>(<><dt class="font-semibold text-gray-700">{k}</dt><dd class="text-gray-600">{v}</dd></>))}
