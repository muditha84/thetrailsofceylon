        </div>
        <div class="bg-white border border-gray-100 rounded-2xl p-5 shadow-sm">
          <h3 class="font-serif font-bold text-gray-900 text-lg mb-4">Nearby Places</h3>
          <div class="space-y-3">
            {[{href:'/places/anuradhapura',label:'Anuradhapura (90km)'},{href:'/places/negombo',label:'Negombo'},{href:'/places/colombo',label:'Colombo (180km)'}].map(link=>(<a href={link.href} class="nearby-pill"><svg class="w-4 h-4 text-gray-300 group-hover:text-ceylon-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>{link.label}</a>))}
          </div>
        </div>
      </aside>
    </div>
  </div>
  <ExpediaWidget heading="🏨 Find Hotels in Wilpattu" />
</BaseLayout>
