          <a href="/" class="hover:text-white">Home</a><span>/</span>
          <a href="/places" class="hover:text-white">Places</a><span>/</span>
          <a href="/places/east-coast" class="hover:text-white">East Coast</a><span>/</span>
          <span class="text-white">Nilaveli</span>
        </nav>
