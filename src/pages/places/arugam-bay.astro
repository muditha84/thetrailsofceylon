            {[{href:'/places/trincomalee',label:'Trincomalee'},{href:'/places/yala',label:'Yala National Park'},{href:'/places/ella',label:'Ella (via Wellawaya)'}].map(link=>(<a href={link.href} class="nearby-pill"><svg class="w-4 h-4 text-gray-300 group-hover:text-ceylon-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>{link.label}</a>))}
