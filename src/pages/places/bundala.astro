            {[["Province","Southern Province"],["Size","6,216 hectares"],["UNESCO","Ramsar Wetland + Biosphere Reserve"],["Best For","Birdwatching, flamingos, crocodiles"],["Season","Year-round; Oct–Mar best for birds"],["From Yala","25km west"]].map(([k, v]) => (
