          <dl class="grid grid-cols-2 gap-x-4 gap-y-2 text-sm">
            {[["Province","North Central Province"],["Size","39,322 hectares"],["Famous For","Large elephant herds, remote setting"],["Best Season","May–September (dry)"],["Crowds","Very low — genuinely remote"],["From Kandy","3 hrs by car"]].map(([k, v]) => (
              <><dt class="font-semibold text-gray-700">{k}</dt><dd class="text-gray-600">{v}</dd></>
            ))}
          </dl>
