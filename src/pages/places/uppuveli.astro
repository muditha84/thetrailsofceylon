    <img src="/images/trincomalee.jpg" alt="Uppuveli beach Trincomalee east coast Sri Lanka" class="w-full h-full object-cover" style="object-fit:cover;" fetchpriority="high" width="800" height="600" />
    <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>
    <div class="absolute bottom-0 left-0 right-0 p-8">
      <div class="max-w-4xl mx-auto">
        <nav class="flex items-center gap-2 text-white/70 text-xs mb-3" aria-label="Breadcrumb">
          <a href="/" class="hover:text-white">Home</a><span>/</span>
          <a href="/places" class="hover:text-white">Places</a><span>/</span>
          <a href="/places/east-coast" class="hover:text-white">East Coast</a><span>/</span>
          <span class="text-white">Uppuveli</span>
        </nav>
        <span class="inline-block bg-ceylon-gold-500 text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide mb-3">East Coast</span>
        <h1 class="font-serif font-black text-white text-4xl sm:text-5xl">Uppuveli</h1>
        <p class="text-white/80 mt-2 text-lg">East Coast • Beach • Trincomalee Strip • WWII Cemetery</p>
