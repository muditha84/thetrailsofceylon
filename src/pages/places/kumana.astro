          <dl class="grid grid-cols-2 gap-x-4 gap-y-2 text-sm">
            {[["Province","Eastern Province"],["Size","35,665 hectares"],["Famous For","Waterbird colony, leopards, elephants"],["Best Season","May–September (east coast dry)"],["From Arugam Bay","45km north"],["Crowds","Extremely low"]].map(([k, v]) => (
