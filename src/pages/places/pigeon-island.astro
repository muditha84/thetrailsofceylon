          <dl class="grid grid-cols-2 gap-x-4 gap-y-2 text-sm">
            {[["Distance from Shore","1km from Nilaveli beach"],["Marine Park","National Park status since 2003"],["Best For","Snorkelling, reef sharks, turtles"],["Best Season","May–September"],["Boat Transfer","10–15 minutes"],["Entry Fee","USD 15 per person (approx)"]].map(([k, v]) => (
