---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CardDestination from '../../components/CardDestination.astro';
import SectionHeader from '../../components/SectionHeader.astro';

const destinations = [
  { href: '/places/sigiriya',     image: '/images/sigiriya.jpg',      title: 'Sigiriya Rock Fortress', subtitle: 'Cultural Triangle', tag: 'Must Visit', description: 'Climb this 5th-century rock citadel rising 200 metres above the jungle. UNESCO World Heritage Site.' },
  { href: '/places/ella',         image: '/images/ella.jpg',          title: 'Ella', subtitle: 'Hill Country', tag: 'Trending', description: 'A misty mountain village loved by backpackers and luxury travellers alike, surrounded by emerald tea estates.' },
  { href: '/places/galle',        image: '/images/galle-fort.jpg',    title: 'Galle Fort', subtitle: 'South Coast', tag: null, description: 'UNESCO-listed Dutch colonial fort with charming cafes, boutique hotels and sweeping ocean views.' },
  { href: '/places/kandy',        image: '/images/kandy.jpg',         title: 'Kandy', subtitle: 'Hill Country', tag: null, description: 'Sri Lanka\'s cultural capital and home to the revered Temple of the Tooth Relic.' },
  { href: '/places/yala',         image: '/images/yala.jpg',          title: 'Yala National Park', subtitle: 'Wildlife Parks', tag: null, description: 'The world\'s highest leopard density. Also home to elephants, sloth bears and crocodiles.' },
  { href: '/places/mirissa',      image: '/images/mirissa-beach.jpg', title: 'Mirissa', subtitle: 'South Coast', tag: null, description: 'Gorgeous crescent beach — Sri Lanka\'s top whale watching departure point.' },
  { href: '/places/polonnaruwa',  image: '/images/polonnaruwa.jpg',          title: 'Polonnaruwa', subtitle: 'Cultural Triangle', tag: null, description: 'A UNESCO-listed ancient capital with magnificent Buddhist shrines, palaces and moats.' },
  { href: '/places/nuwara-eliya', image: '/images/tea-plantation.jpg',title: 'Nuwara Eliya', subtitle: 'Hill Country', tag: null, description: 'Little England in the clouds — Sri Lanka\'s highest city, ringed by world-famous tea estates.' },
  { href: '/places/trincomalee',  image: '/images/trincomalee.jpg',          title: 'Trincomalee', subtitle: 'East Coast', tag: null, description: 'One of the world\'s finest natural harbours — and home to stunning Nilaveli beach.' },
  { href: '/places/arugam-bay',   image: '/images/arugam-bay.jpg',          title: 'Arugam Bay', subtitle: 'East Coast', tag: null, description: 'One of Asia\'s top surf spots, with a chilled-out vibe and world-class point breaks.' },
  { href: '/places/anuradhapura', image: '/images/anuradhapura.jpg',          title: 'Anuradhapura', subtitle: 'Cultural Triangle', tag: null, description: 'Sri Lanka\'s first ancient capital — a vast UNESCO site with towering dagobas and the sacred Bodhi Tree.' },
  { href: '/places/jaffna',       image: '/images/jaffna.jpg',          title: 'Jaffna', subtitle: 'North & Jaffna', tag: null, description: 'The Tamil cultural capital of Sri Lanka — ancient kovils, island cycling, and a distinctive cuisine.' },
];
---

<BaseLayout
  title="Places to Visit in Sri Lanka | The Trails of Ceylon"
  description="Discover the best places to visit in Sri Lanka — from ancient ruins and misty highlands to beautiful beaches and wildlife parks."
>
  <!-- Page Header -->
  <section class="bg-ceylon-green-900 py-20 relative overflow-hidden">
    <div class="absolute inset-0 opacity-30">
      <img
        src="/images/sigiriya.jpg"
        alt=""
        class="w-full h-full object-cover object-center"
        loading="eager"
        width="1920"
        height="600"
      />
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-ceylon-gold-400 text-xs font-semibold uppercase tracking-widest mb-3">Explore Sri Lanka</p>
      <h1 class="font-serif font-black text-white text-5xl sm:text-6xl mb-4">Places to Visit</h1>
      <p class="text-ceylon-green-200 text-lg max-w-2xl mx-auto">
        From ancient kingdoms to pristine beaches — discover the most beautiful and fascinating destinations across Sri Lanka.
      </p>
    </div>
  </section>

  <!-- Filter Tabs -->
  <section class="bg-white border-b border-gray-100 sticky top-16 lg:top-20 z-40">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-2 overflow-x-auto py-3 scrollbar-none">
        {[
          { label: 'All', href: '/places' },
          { label: 'Cultural Triangle', href: '/places/cultural-triangle' },
          { label: 'Hill Country', href: '/places/hill-country' },
          { label: 'South Coast', href: '/places/south-coast' },
          { label: 'East Coast', href: '/places/east-coast' },
          { label: 'Wildlife Parks', href: '/places/wildlife-parks' },
          { label: 'North & Jaffna', href: '/places/north-jaffna' },
        ].map((tab, i) => (
          <a
            href={tab.href}
            class={`whitespace-nowrap px-4 py-2 rounded-full text-sm font-medium transition-colors ${i === 0 ? 'bg-ceylon-green-700 text-white' : 'text-gray-600 hover:bg-gray-100'}`}
          >
            {tab.label}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Destinations Grid -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {destinations.map(dest => (
          <CardDestination {...dest} />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
