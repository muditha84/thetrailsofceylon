---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CardDestination from '../../components/CardDestination.astro';
import SectionHeader from '../../components/SectionHeader.astro';

const destinations = [
  { href: '/places/sigiriya',     image: '/images/sigiriya.jpg',      title: 'Sigiriya Rock Fortress', subtitle: 'Cultural Triangle', tag: 'Must Visit', description: 'Climb this 5th-century rock citadel rising 200 metres above the jungle. UNESCO World Heritage Site.' },
  { href: '/places/ella',         image: '/images/ella.jpg',          title: 'Ella', subtitle: 'Hill Country', tag: 'Trending', description: 'A misty mountain village loved by backpackers and luxury travellers alike, surrounded by emerald tea estates.' },
  { href: '/places/galle',        image: '/images/galle-fort.jpg',    title: 'Galle Fort', subtitle: 'South Coast', tag: null, description: 'UNESCO-listed Dutch colonial fort with charming cafes, boutique hotels and sweeping ocean views.' },
  { href: '/places/kandy',        image: '/images/kandy.jpg',         title: 'Kandy', subtitle: 'Hill Country', tag: null, description: 'Sri Lanka\'s cultural capital and home to the revered Temple of the Tooth Relic.' },
  { href: '/places/yala',         image: '/images/yala.jpg',          title: 'Yala National Park', subtitle: 'Wildlife Parks', tag: null, description: 'The world\'s highest leopard density. Also home to elephants, sloth bears and crocodiles.' },
  { href: '/places/mirissa',      image: '/images/mirissa-beach.jpg', title: 'Mirissa', subtitle: 'South Coast', tag: null, description: 'Gorgeous crescent beach — Sri Lanka\'s top whale watching departure point.' },
  { href: '/places/polonnaruwa',  image: '/images/polonnaruwa.jpg',          title: 'Polonnaruwa', subtitle: 'Cultural Triangle', tag: null, description: 'A UNESCO-listed ancient capital with magnificent Buddhist shrines, palaces and moats.' },
  { href: '/places/nuwara-eliya', image: '/images/tea-plantation.jpg',title: 'Nuwara Eliya', subtitle: 'Hill Country', tag: null, description: 'Little England in the clouds — Sri Lanka\'s highest city, ringed by world-famous tea estates.' },
  { href: '/places/trincomalee',  image: '/images/trincomalee.jpg',          title: 'Trincomalee', subtitle: 'East Coast', tag: null, description: 'One of the world\'s finest natural harbours — and home to stunning Nilaveli beach.' },
  { href: '/places/arugam-bay',   image: '/images/arugam-bay.jpg',          title: 'Arugam Bay', subtitle: 'East Coast', tag: null, description: 'One of Asia\'s top surf spots, with a chilled-out vibe and world-class point breaks.' },
  { href: '/places/anuradhapura', image: '/images/anuradhapura.jpg',          title: 'Anuradhapura', subtitle: 'Cultural Triangle', tag: null, description: 'Sri Lanka\'s first ancient capital — a vast UNESCO site with towering dagobas and the sacred Bodhi Tree.' },
  { href: '/places/jaffna',           image: '/images/jaffna.jpg',          title: 'Jaffna', subtitle: 'North & Jaffna', tag: null, description: 'The Tamil cultural capital of Sri Lanka — ancient kovils, island cycling, and a distinctive cuisine.' },
  { href: '/places/hikkaduwa',        image: '/images/hikkaduwa.jpg',       title: 'Hikkaduwa', subtitle: 'South Coast', tag: null, description: 'Sri Lanka\'s original beach resort — coral reef snorkelling, surf breaks and beach bar life.' },
  { href: '/places/bentota',          image: '/images/bentota.jpg',         title: 'Bentota', subtitle: 'South Coast', tag: null, description: 'Luxury beach resort town with river safaris, water sports and colonial-era hotels.' },
  { href: '/places/hiriketiya',       image: '/images/hiriketiya.jpg',      title: 'Hiriketiya', subtitle: 'South Coast', tag: null, description: 'A sheltered horseshoe bay perfect for beginner surfing and yoga retreats.' },
  { href: '/places/dikwella',         image: '/images/dikwella.jpg',        title: 'Dikwella', subtitle: 'South Coast', tag: null, description: 'Wild, unspoilt beach with Sri Lanka\'s largest seated Buddha statue nearby.' },
  { href: '/places/nilaveli',         image: '/images/nilaveli.jpg',        title: 'Nilaveli', subtitle: 'East Coast', tag: null, description: 'White-sand beach near Trincomalee — gateway to Pigeon Island coral reef.' },
  { href: '/places/uppuveli',         image: '/images/uppuveli.jpg',        title: 'Uppuveli', subtitle: 'East Coast', tag: null, description: 'Quiet, beautiful beach just north of Trincomalee, perfect for escaping the crowds.' },
  { href: '/places/kalpitiya',        image: '/images/kalpitiya.jpg',       title: 'Kalpitiya', subtitle: 'Northwest', tag: null, description: 'Sri Lanka\'s kitesurfing capital, with dolphin watching and dolphin safaris.' },
  { href: '/places/batticaloa',       image: '/images/batticaloa.jpg',      title: 'Batticaloa', subtitle: 'East Coast', tag: null, description: 'The Singing Fish lagoon, Dutch fort ruins and a city slowly rediscovering tourism.' },
  { href: '/places/mannar',           image: '/images/mannar.jpg',          title: 'Mannar', subtitle: 'North Sri Lanka', tag: null, description: 'Remote island with ancient baobab trees, bird watching and the ruins of a Portuguese fort.' },
  { href: '/places/adams-peak',       image: '/images/ella.jpg',            title: "Adam's Peak", subtitle: 'Hill Country', tag: null, description: 'Sri Lanka\'s sacred mountain — an overnight pilgrimage climb for a legendary sunrise.' },
  { href: '/places/nine-arch-bridge', image: '/images/nine-arch-bridge.jpg', title: 'Nine Arch Bridge', subtitle: 'Hill Country', tag: null, description: 'The iconic colonial viaduct framed by jungle — Ella\'s most photographed sight.' },
  { href: '/places/pigeon-island',    image: '/images/pigeon-island.jpg',   title: 'Pigeon Island', subtitle: 'East Coast', tag: null, description: 'Sri Lanka\'s best snorkelling — blacktip reef sharks and coral gardens off Nilaveli.' },
  { href: '/places/delft-island',     image: '/images/mannar.jpg',          title: 'Delft Island', subtitle: 'North Sri Lanka', tag: null, description: 'A wild, windswept island of wild ponies, coral walls and ancient ruins near Jaffna.' },
  { href: '/places/ambuluwawa',       image: '/images/kandy.jpg',           title: 'Ambuluwawa', subtitle: 'Hill Country', tag: null, description: 'A striking multi-religious tower and biodiversity complex with 360° hilltop views.' },
  { href: '/places/worlds-end',       image: '/images/horton-plains.jpg',   title: "World's End", subtitle: 'Hill Country', tag: null, description: 'An 870-metre sheer cliff drop at Horton Plains — one of Sri Lanka\'s most dramatic viewpoints.' },
  { href: '/places/ravana-falls',     image: '/images/ella.jpg',            title: 'Ravana Falls', subtitle: 'Hill Country', tag: null, description: 'Mythological waterfall beside the road near Ella — popular swimming and photo stop.' },
  { href: '/places/diyaluma-falls',   image: '/images/ella.jpg',            title: 'Diyaluma Falls', subtitle: 'Hill Country', tag: null, description: 'Sri Lanka\'s highest waterfall at 220m, with natural rock pools at the top.' },
  { href: '/places/bundala',          image: '/images/yala.jpg',            title: 'Bundala National Park', subtitle: 'Wildlife Parks', tag: null, description: 'Ramsar wetland reserve and prime flamingo habitat on the south coast.' },
  { href: '/places/wasgamuwa',        image: '/images/yala.jpg',            title: 'Wasgamuwa', subtitle: 'Wildlife Parks', tag: null, description: 'Remote highland park with large elephant herds and sloth bears, near the Cultural Triangle.' },
  { href: '/places/kumana',           image: '/images/yala.jpg',            title: 'Kumana National Park', subtitle: 'Wildlife Parks', tag: null, description: 'East coast wilderness bordering Yala — birds, leopards and a famous waterbird nesting colony.' },
  { href: '/places/pinnawala',        image: '/images/pinnawala.jpg',       title: 'Pinnawala Elephant Orphanage', subtitle: 'Wildlife', tag: null, description: 'Watch 80+ rescued elephants bathe in the river — Sri Lanka\'s most iconic wildlife experience.' },
  { href: '/places/gangaramaya-temple', image: '/images/kandy.jpg',         title: 'Gangaramaya Temple', subtitle: 'Colombo', tag: null, description: 'Colombo\'s most eclectic Buddhist temple — a surreal collection of Buddha statues and religious art.' },
  { href: '/places/galle-face-green', image: '/images/colombo.jpg',         title: 'Galle Face Green', subtitle: 'Colombo', tag: null, description: "Colombo's beloved oceanfront promenade — street food, kite-flying and Indian Ocean sunsets." },
  { href: '/places/matara',           image: '/images/mirissa-beach.jpg',   title: 'Matara', subtitle: 'South Coast', tag: null, description: 'Southern city with Dutch fort, surf beach and the southernmost railway station.' },
];
---

<BaseLayout
  title="Places to Visit in Sri Lanka | The Trails of Ceylon"
  description="Discover the best places to visit in Sri Lanka — from ancient ruins and misty highlands to beautiful beaches and wildlife parks."
>
  <!-- Page Header -->
  <section class="bg-ceylon-green-900 py-20 relative overflow-hidden">
    <div class="absolute inset-0 opacity-30">
      <img
        src="/images/sigiriya.jpg"
        alt=""
        class="w-full h-full object-cover object-center"
        loading="eager"
        width="1920"
        height="600"
      />
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-ceylon-gold-400 text-xs font-semibold uppercase tracking-widest mb-3">Explore Sri Lanka</p>
      <h1 class="font-serif font-black text-white text-5xl sm:text-6xl mb-4">Places to Visit</h1>
      <p class="text-ceylon-green-200 text-lg max-w-2xl mx-auto">
        From ancient kingdoms to pristine beaches — discover the most beautiful and fascinating destinations across Sri Lanka.
      </p>
    </div>
  </section>

  <!-- Filter Tabs -->
  <section class="bg-white border-b border-gray-100 sticky top-16 lg:top-20 z-40">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-2 overflow-x-auto py-3 scrollbar-none">
        {[
          { label: 'All', href: '/places' },
          { label: 'Cultural Triangle', href: '/places/cultural-triangle' },
          { label: 'Hill Country', href: '/places/hill-country' },
          { label: 'South Coast', href: '/places/south-coast' },
          { label: 'East Coast', href: '/places/east-coast' },
          { label: 'Wildlife Parks', href: '/places/wildlife-parks' },
          { label: 'North & Jaffna', href: '/places/north-jaffna' },
        ].map((tab, i) => (
          <a
            href={tab.href}
            class={`whitespace-nowrap px-4 py-2 rounded-full text-sm font-medium transition-colors ${i === 0 ? 'bg-ceylon-green-700 text-white' : 'text-gray-600 hover:bg-gray-100'}`}
          >
            {tab.label}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Destinations Grid -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {destinations.map(dest => (
          <CardDestination {...dest} />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
