---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Wildlife & Nature in Sri Lanka | The Trails of Ceylon" description="Sri Lanka's wildlife and nature experiences — leopard safaris at Yala, whale watching off Mirissa, elephant gatherings at Minneriya, and bird watching in cloud forest." type="article" publishDate="2025-03-15">
  <div class="relative h-[50vh] min-h-[350px] overflow-hidden">
    <img src="/images/yala.jpg" alt="Leopard in Yala National Park, Sri Lanka" class="w-full h-full object-cover" style="object-fit:cover;" fetchpriority="high" width="800" height="600" />
    <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>
    <div class="absolute bottom-0 left-0 right-0 p-8">
      <div class="max-w-4xl mx-auto">
        <nav class="flex items-center gap-2 text-white/70 text-xs mb-3" aria-label="Breadcrumb">
          <a href="/" class="hover:text-white">Home</a><span>/</span><a href="/things-to-do" class="hover:text-white">Things to Do</a><span>/</span><span class="text-white">Wildlife & Nature</span>
        </nav>
        <h1 class="font-serif font-black text-white text-4xl sm:text-5xl">Wildlife & Nature</h1>
        <p class="text-white/80 mt-2 text-lg">Sri Lanka's extraordinary natural world</p>
      </div>
    </div>
  </div>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-14">
    <p class="text-xl text-gray-600 mb-12 max-w-3xl">For an island its size, Sri Lanka's wildlife is extraordinary. The world's highest leopard density, Asia's largest elephant gathering, blue whale sightings year-round, and 250+ bird species — including 33 endemics found nowhere else on Earth.</p>
    <div class="grid sm:grid-cols-2 lg:grid-cols-2 gap-6">
      {[
        {href:'/things-to-do/wildlife-safaris',img:'/images/yala.jpg',alt:'Leopard safari Sri Lanka',badge:'Wildlife',title:'Wildlife Safaris',desc:'Leopards at Yala, elephant gatherings at Minneriya, sloth bears at Wilpattu — Sri Lanka\'s national parks rival the best in the world.'},
        {href:'/things-to-do/whale-watching',img:'/images/whale-watching.jpg',alt:'Blue whale off Mirissa Sri Lanka',badge:'Marine',title:'Whale Watching',desc:'Mirissa is one of the world\'s best places to see blue whales and sperm whales — often within 20km of shore.'},
        {href:'/things-to-do/bird-watching',img:'/images/hero.jpg',alt:'Bird watching Sri Lanka',badge:'Nature',title:'Bird Watching',desc:'33 endemic species and 250+ recorded species — the Sinharaja rainforest and the highland forests are world-class birding destinations.'},
        {href:'/things-to-do/snorkelling',img:'/images/hero.jpg',alt:'Snorkelling Sri Lanka',badge:'Marine',title:'Snorkelling & Diving',desc:'Pigeon Island off Trincomalee has pristine coral reefs. The south coast offers turtle encounters and wreck dives year-round.'},
      ].map(c=>(
        <a href={c.href} class="group rounded-2xl overflow-hidden bg-white shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
          <div class="aspect-[4/3] overflow-hidden">
            <img src={c.img} alt={c.alt} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" width="400" height="300" loading="lazy" />
          </div>
          <div class="p-5">
            <span class="text-xs font-bold uppercase tracking-wide text-ceylon-green-700">{c.badge}</span>
            <h2 class="font-serif font-bold text-gray-900 text-xl mt-1 mb-2">{c.title}</h2>
            <p class="text-gray-600 text-sm leading-relaxed">{c.desc}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
