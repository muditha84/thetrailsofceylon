---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CardDestination from '../../components/CardDestination.astro';
import SectionHeader from '../../components/SectionHeader.astro';

const activities = [
  { href: '/things-to-do/whale-watching',       image: '/images/whale-watching.jpg',  title: 'Whale Watching',              subtitle: 'Ocean Experience',   tag: 'Popular',  description: 'Spot blue whales and sperm whales just off Mirissa and Trincomalee between November and April.' },
  { href: '/things-to-do/wildlife-safaris',      image: '/images/yala.jpg',            title: 'Wildlife Safaris',            subtitle: 'National Parks',     tag: null,       description: 'Track leopards, elephants and crocodiles in Yala, Udawalawe and Minneriya national parks.' },
  { href: '/things-to-do/hiking',               image: '/images/ella.jpg',            title: 'Hiking',                      subtitle: 'Trails & Trekking',  tag: null,       description: "Adam's Peak overnight climb, Ella Rock at dawn, Horton Plains plateau, Knuckles Range multi-day treks." },
  { href: '/things-to-do/surfing',              image: '/images/mirissa-beach.jpg',   title: 'Surfing',                     subtitle: 'East & South Coast', tag: null,       description: 'Sri Lanka has world-class breaks at Arugam Bay, Weligama and Hikkaduwa — waves for every level.' },
  { href: '/things-to-do/train-rides',          image: '/images/scenic-train.jpg',    title: 'Scenic Train Rides',          subtitle: 'Highland Railways',  tag: null,       description: 'Ride the iconic Kandy to Ella train through misty mountains, waterfalls and emerald tea terraces.' },
  { href: '/things-to-do/tea-plantation-tours', image: '/images/tea-plantation.jpg',  title: 'Tea Plantation Tours',        subtitle: 'Hill Country',       tag: null,       description: 'Walk through vast emerald estates and learn how world-famous Ceylon tea is grown, picked and processed.' },
  { href: '/things-to-do/snorkelling',          image: '/images/hero.jpg',            title: 'Snorkelling & Diving',        subtitle: 'Coastal Waters',     tag: null,       description: 'Coral reefs at Pigeon Island, sea turtles at Hikkaduwa, and wreck dives off the south coast.' },
  { href: '/things-to-do/bird-watching',        image: '/images/hero.jpg',            title: 'Bird Watching',               subtitle: 'Wildlife & Nature',  tag: null,       description: '33 endemic species found nowhere else on Earth — Sinharaja rainforest is world-class birding territory.' },
  { href: '/things-to-do/white-water-rafting',  image: '/images/hero.jpg',            title: 'White-Water Rafting',         subtitle: 'Adventure',          tag: null,       description: 'Grade 2–4 rapids on the Kelani River at Kitulgala — the best adventure day trip from Colombo.' },
  { href: '/things-to-do/cycling',              image: '/images/hero.jpg',            title: 'Cycling',                     subtitle: 'Adventure',          tag: null,       description: 'Cycle between ancient ruins in the Cultural Triangle, through tea estates, or around the Jaffna islands.' },
  { href: '/things-to-do/temple-visits',        image: '/images/sigiriya.jpg',        title: 'Temple Visits',               subtitle: 'Culture & Heritage', tag: null,       description: "The Temple of the Tooth, Dambulla caves, Anuradhapura's ancient stupas — Sri Lanka's sacred sites are extraordinary." },
  { href: '/things-to-do/ayurveda',             image: '/images/hero.jpg',            title: 'Ayurveda & Wellness',         subtitle: 'Spa & Wellness',     tag: null,       description: 'From single spa treatments to 14-day panchakarma retreats — Sri Lanka\'s Ayurvedic tradition is 3,000 years old.' },
  { href: '/things-to-do/cooking-classes',      image: '/images/hero.jpg',            title: 'Sri Lankan Cooking Classes',  subtitle: 'Food & Culture',     tag: null,       description: 'Learn to cook rice and curry, hoppers and pol sambol from scratch in a family home or cooking school.' },
];
---

<BaseLayout
  title="Things to Do in Sri Lanka | The Trails of Ceylon"
  description="Discover the best activities and experiences in Sri Lanka — whale watching, safaris, surfing, tea tours, train rides and much more."
>
  <section class="bg-ceylon-green-900 py-20 relative overflow-hidden">
    <div class="absolute inset-0 opacity-30">
      <img
        src="/images/whale-watching.jpg"
        alt=""
        class="w-full h-full object-cover object-center"
        loading="eager"
        width="1920"
        height="600"
      />
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-ceylon-gold-400 text-xs font-semibold uppercase tracking-widest mb-3">Activities & Experiences</p>
      <h1 class="font-serif font-black text-white text-5xl sm:text-6xl mb-4">Things to Do</h1>
      <p class="text-ceylon-green-200 text-lg max-w-2xl mx-auto">
        From riding ancient railways to swimming with whale sharks — Sri Lanka is a playground for the adventurous and curious traveller.
      </p>
    </div>
  </section>

  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {activities.map(act => (
          <CardDestination {...act} />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
