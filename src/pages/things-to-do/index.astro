---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CardDestination from '../../components/CardDestination.astro';
import SectionHeader from '../../components/SectionHeader.astro';

const activities = [
  { href: '/things-to-do/whale-watching',       image: '/images/whale-watching.webp',  title: 'Whale Watching',              subtitle: 'Ocean Experience',   tag: 'Popular',  description: 'Spot blue whales and sperm whales just off Mirissa and Trincomalee between November and April.' },
  { href: '/things-to-do/wildlife-safaris',      image: '/images/yala.webp',            title: 'Wildlife Safaris',            subtitle: 'National Parks',     tag: null,       description: 'Track leopards, elephants and crocodiles in Yala, Udawalawe and Minneriya national parks.' },
  { href: '/things-to-do/hiking',               image: '/images/ella.webp',            title: 'Hiking',                      subtitle: 'Trails & Trekking',  tag: null,       description: "Adam's Peak overnight climb, Ella Rock at dawn, Horton Plains plateau, Knuckles Range multi-day treks." },
  { href: '/things-to-do/surfing',              image: '/images/mirissa-beach.webp',   title: 'Surfing',                     subtitle: 'East & South Coast', tag: null,       description: 'Sri Lanka has world-class breaks at Arugam Bay, Weligama and Hikkaduwa — waves for every level.' },
  { href: '/things-to-do/train-rides',          image: '/images/scenic-train.webp',    title: 'Scenic Train Rides',          subtitle: 'Highland Railways',  tag: null,       description: 'Ride the iconic Kandy to Ella train through misty mountains, waterfalls and emerald tea terraces.' },
  { href: '/things-to-do/tea-plantation-tours', image: '/images/tea-plantation.webp',  title: 'Tea Plantation Tours',        subtitle: 'Hill Country',       tag: null,       description: 'Walk through vast emerald estates and learn how world-famous Ceylon tea is grown, picked and processed.' },
  { href: '/things-to-do/snorkelling',          image: '/images/snorkelling.webp',            title: 'Snorkelling & Diving',        subtitle: 'Coastal Waters',     tag: null,       description: 'Coral reefs at Pigeon Island, sea turtles at Hikkaduwa, and wreck dives off the south coast.' },
  { href: '/things-to-do/bird-watching',        image: '/images/bird-watching.webp',            title: 'Bird Watching',               subtitle: 'Wildlife & Nature',  tag: null,       description: '33 endemic species found nowhere else on Earth — Sinharaja rainforest is world-class birding territory.' },
  { href: '/things-to-do/white-water-rafting',  image: '/images/white-water-rafting.webp',            title: 'White-Water Rafting',         subtitle: 'Adventure',          tag: null,       description: 'Grade 2–4 rapids on the Kelani River at Kitulgala — the best adventure day trip from Colombo.' },
  { href: '/things-to-do/cycling',              image: '/images/cycling.webp',            title: 'Cycling',                     subtitle: 'Adventure',          tag: null,       description: 'Cycle between ancient ruins in the Cultural Triangle, through tea estates, or around the Jaffna islands.' },
  { href: '/things-to-do/temple-visits',        image: '/images/sigiriya.webp',        title: 'Temple Visits',               subtitle: 'Culture & Heritage', tag: null,       description: "The Temple of the Tooth, Dambulla caves, Anuradhapura's ancient stupas — Sri Lanka's sacred sites are extraordinary." },
  { href: '/things-to-do/ayurveda',             image: '/images/ayurveda.webp',            title: 'Ayurveda & Wellness',         subtitle: 'Spa & Wellness',     tag: null,       description: 'From single spa treatments to 14-day panchakarma retreats — Sri Lanka\'s Ayurvedic tradition is 3,000 years old.' },
  { href: '/things-to-do/cooking-classes',      image: '/images/cooking-classes.webp',            title: 'Sri Lankan Cooking Classes',  subtitle: 'Food & Culture',     tag: null,       description: 'Learn to cook rice and curry, hoppers and pol sambol from scratch in a family home or cooking school.' },
  { href: '/things-to-do/hot-air-ballooning',   image: '/images/hot-air-ballooning.webp',                   title: 'Hot Air Ballooning',          subtitle: 'Adventure',          tag: null,       description: 'Drift over Sigiriya and Dambulla at sunrise — the Cultural Triangle from 1,000 feet up.' },
  { href: '/things-to-do/scuba-diving',         image: '/images/scuba-diving.webp',                title: 'Scuba Diving',                subtitle: 'Ocean Experience',   tag: null,       description: 'Dive the coral reefs, sea caves and historic wrecks scattered around Sri Lanka\'s coastline.' },
  { href: '/things-to-do/dolphin-watching',     image: '/images/dolphin-watching.webp',              title: 'Dolphin Watching',            subtitle: 'Ocean Experience',   tag: null,       description: 'Spinner dolphin pods in the hundreds off Kalpitiya — one of the world\'s best dolphin spectacles.' },
  { href: '/things-to-do/turtle-watching',      image: '/images/turtle-watching.webp',              title: 'Turtle Watching',             subtitle: 'Wildlife & Nature',  tag: null,       description: 'Five sea turtle species nest on Sri Lanka\'s beaches — watch nesting and hatchling releases.' },
  { href: '/things-to-do/rock-climbing',        image: '/images/rock-climbing.webp',                       title: 'Rock Climbing',               subtitle: 'Adventure',          tag: null,       description: 'Granite crags, jungle outcrops and Sigiriya-style bouldering across the island.' },
  { href: '/things-to-do/waterfall-hiking',     image: '/images/waterfall-hiking.webp',                       title: 'Waterfall Hiking',            subtitle: 'Trails & Nature',    tag: null,       description: 'Trek to Sri Lanka\'s most spectacular falls — Diyaluma, Ravana, Baker\'s and more.' },
  { href: '/things-to-do/stilt-fishing',        image: '/images/stilt-fishing.webp',              title: 'Stilt Fishing',               subtitle: 'Culture & Heritage', tag: null,       description: 'Watch (or try) the unique stilt fishing technique practised south of Galle for generations.' },
  { href: '/things-to-do/kitesurfing',          image: '/images/kitesurfing.webp',                  title: 'Kitesurfing',                 subtitle: 'Adventure',          tag: null,       description: 'Kalpitiya\'s flat lagoon and reliable trade winds make it one of Asia\'s top kite destinations.' },
  { href: '/things-to-do/deep-sea-fishing',     image: '/images/deep-sea-fishing.webp',              title: 'Deep Sea Fishing',            subtitle: 'Ocean Experience',   tag: null,       description: 'Blue marlin, sailfish and yellowfin tuna in the deep waters off Mirissa and Trincomalee.' },
  { href: '/things-to-do/temple-hopping',       image: '/images/sigiriya.webp',                   title: 'Temple Hopping',              subtitle: 'Culture & Heritage', tag: null,       description: 'From Dambulla cave paintings to Anuradhapura stupas — Sri Lanka\'s temple circuit is extraordinary.' },
  { href: '/things-to-do/camping',              image: '/images/camping.webp',              title: 'Camping & Glamping',          subtitle: 'Adventure',          tag: null,       description: 'Camp under the stars in the Cultural Triangle, hill country or national park buffer zones.' },
  { href: '/things-to-do/pidurangala-rock',     image: '/images/pidurangala.webp',                   title: 'Pidurangala Rock',            subtitle: 'Hiking',             tag: null,       description: "The best view of Sigiriya Rock — a short but steep hike to a summit that outshines its famous neighbour." },
  { href: '/things-to-do/rope-swing',           image: '/images/rope-swing.webp',                       title: 'Rope Swings & Cliff Jumps',   subtitle: 'Adventure',          tag: null,       description: 'Freshwater rope swings and cliff jumps at Kitulgala, Ella and waterfall swimming holes.' },
  { href: '/things-to-do/tuk-tuk-tours',        image: '/images/tuk-tuk.webp',                          title: 'Tuk Tuk Tours',               subtitle: 'Getting Around',     tag: null,       description: 'Hire a three-wheeler for the day, use PickMe app in cities, or embark on a tuk tuk road trip across the island.' },
];
---

<BaseLayout
  title="Things to Do in Sri Lanka | The Trails of Ceylon"
  description="Discover the best activities and experiences in Sri Lanka — whale watching, safaris, surfing, tea tours, train rides and much more."
>
  <section class="bg-ceylon-green-900 py-20 relative overflow-hidden">
    <div class="absolute inset-0 opacity-30">
      <img
        src="/images/whale-watching.webp"
        alt=""
        class="w-full h-full object-cover object-center"
        loading="eager"
        width="1920"
        height="600"
      />
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-ceylon-gold-400 text-xs font-semibold uppercase tracking-widest mb-3">Activities & Experiences</p>
      <h1 class="font-serif font-black text-white text-5xl sm:text-6xl mb-4">Things to Do</h1>
      <p class="text-ceylon-green-200 text-lg max-w-2xl mx-auto">
        From riding ancient railways to swimming with whale sharks — Sri Lanka is a playground for the adventurous and curious traveller.
      </p>
    </div>
  </section>

  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {activities.map(act => (
          <CardDestination {...act} />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
