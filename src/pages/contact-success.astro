---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Message Sent | The Trails of Ceylon"
  description="Thank you for getting in touch with The Trails of Ceylon."
>
  <section class="min-h-[70vh] flex items-center justify-center py-20 bg-gray-50">
    <div class="max-w-lg mx-auto px-4 sm:px-6 text-center">
      <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-10 sm:p-14">
        <span class="text-6xl block mb-6">✅</span>
        <h1 class="font-serif font-bold text-gray-900 text-3xl sm:text-4xl mb-4">
          Thank you for getting in touch!
        </h1>
        <p class="text-gray-600 text-lg leading-relaxed mb-8">
          We'll get back to you within 48 hours.
        </p>
        <a
          href="/"
          class="inline-flex items-center gap-2 bg-ceylon-green-700 hover:bg-ceylon-green-800 text-white font-semibold px-8 py-3.5 rounded-full transition-colors text-sm"
        >
          ← Back to Homepage
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
