---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Message Sent | The Trails of Ceylon" description="Thank you for contacting The Trails of Ceylon">
  <section style="min-height:60vh; display:flex; align-items:center; justify-content:center; text-align:center; padding:4rem 2rem;">
    <div>
      <div style="font-size:4rem; margin-bottom:1rem;">✅</div>
      <h1 style="font-size:2.5rem; margin-bottom:1rem; color:#2d5a27;">Message Sent!</h1>
      <p style="font-size:1.2rem; color:#666; margin-bottom:2rem; max-width:500px;">Thank you for getting in touch. We'll get back to you within 48 hours.</p>
      <a href="/" style="background:#2d5a27; color:#fff; padding:0.75rem 2rem; border-radius:50px; text-decoration:none; font-weight:600;">Back to Home</a>
    </div>
  </section>
</BaseLayout>
