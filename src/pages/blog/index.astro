---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CardBlog from '../../components/CardBlog.astro';
import SectionHeader from '../../components/SectionHeader.astro';

const featured = {
  href: '/blog/2-weeks-in-sri-lanka-itinerary',
  image: '/images/scenic-train.jpg',
  title: 'The Perfect 2-Week Sri Lanka Itinerary: Everything You Need to Know',
  category: 'Itineraries',
  date: 'April 10, 2025',
  readTime: '12 min',
  excerpt: 'From ancient ruins in the Cultural Triangle to the misty hill country, the southern beaches and wildlife safaris — this expertly crafted 2-week itinerary hits all the highlights of Sri Lanka without feeling rushed.',
};

const posts = [
  { href: '/blog/best-beaches-sri-lanka',   image: '/images/mirissa-beach.jpg', title: "Sri Lanka's 10 Best Beaches",                    category: 'Beaches',        date: 'Mar 28, 2025', readTime: '8 min',  excerpt: "From surfers' paradise to hidden coves — discover Sri Lanka's most beautiful beaches." },
  { href: '/blog/sri-lanka-budget-travel',   image: '/images/colombo.jpg', title: 'Sri Lanka on a Budget: How to Travel Cheap',       category: 'Budget Travel',  date: 'Mar 15, 2025', readTime: '10 min', excerpt: 'Everything you need to visit Sri Lanka without breaking the bank — accommodation, food, transport.' },
  { href: '/blog/ella-rock-hike',            image: '/images/ella.jpg', title: 'Hiking Ella Rock: A Complete Guide',               category: 'Hiking',         date: 'Mar 5, 2025',  readTime: '7 min',  excerpt: 'The most rewarding hike in Sri Lanka — a step-by-step guide to Ella Rock with tips on routes and timing.' },
  { href: '/blog/sri-lanka-food-guide',      image: '/images/cooking-classes.jpg', title: 'Sri Lankan Food: What to Eat & Where',             category: 'Food & Drink',   date: 'Feb 22, 2025', readTime: '9 min',  excerpt: 'A delicious guide to Sri Lankan cuisine — from coconut sambol to hoppers, rice and curry to kottu roti.' },
  { href: '/blog/best-time-visit-sri-lanka', image: '/images/heroes/hero-hills.jpg', title: 'Best Time to Visit Sri Lanka (Month by Month)',     category: 'Planning',       date: 'Feb 10, 2025', readTime: '11 min', excerpt: "Sri Lanka's two monsoon seasons make timing crucial. Here's exactly when to go for your itinerary." },
  { href: '/blog/sigiriya-tips',             image: '/images/sigiriya.jpg', title: '10 Essential Tips for Visiting Sigiriya',           category: 'Cultural Sites', date: 'Jan 30, 2025', readTime: '6 min',  excerpt: 'Everything first-time visitors need to know before climbing the iconic Lion Rock fortress.' },
];

const categories = ['All', 'Itineraries', 'Beaches', 'Wildlife', 'Hiking', 'Budget Travel', 'Food & Drink', 'Planning', 'Cultural Sites'];
---

<BaseLayout
  title="Sri Lanka Travel Blog | The Trails of Ceylon"
  description="Expert Sri Lanka travel articles, guides, tips and itineraries — everything you need to plan your perfect Sri Lanka trip."
>
  <!-- Header -->
  <section class="bg-ceylon-green-900 py-20 relative overflow-hidden">
    <div class="absolute inset-0 opacity-25">
      <img
        src="/images/tea-plantation.jpg"
        alt=""
        class="w-full h-full object-cover object-center"
        loading="eager"
        width="1920"
        height="600"
      />
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-ceylon-gold-400 text-xs font-semibold uppercase tracking-widest mb-3">Sri Lanka Travel Blog</p>
      <h1 class="font-serif font-black text-white text-5xl sm:text-6xl mb-4">Travel Stories & Guides</h1>
      <p class="text-ceylon-green-200 text-lg max-w-2xl mx-auto">Honest, expert travel content to help you explore Sri Lanka with confidence.</p>
    </div>
  </section>

  <!-- Categories -->
  <section class="bg-white border-b border-gray-100 sticky top-16 lg:top-20 z-40">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-2 overflow-x-auto py-3">
        {categories.map((cat, i) => (
          <button class={`whitespace-nowrap px-4 py-2 rounded-full text-sm font-medium transition-colors ${i === 0 ? 'bg-ceylon-green-700 text-white' : 'text-gray-600 hover:bg-gray-100'}`}>
            {cat}
          </button>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Featured post -->
      <a href={featured.href} class="group block mb-14 bg-white rounded-3xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300">
        <div class="grid md:grid-cols-[3fr_2fr]">
          <div class="relative overflow-hidden aspect-[16/9] md:aspect-auto min-h-[280px]">
            <img
              src={featured.image}
              alt={featured.title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="eager"
              width="960"
              height="540"
              style="object-fit:cover;"
            />
            <span class="absolute top-5 left-5 bg-ceylon-gold-500 text-white text-xs font-bold px-3 py-1.5 rounded-full uppercase tracking-wide">Featured</span>
          </div>
          <div class="p-8 lg:p-10 flex flex-col justify-center">
            <span class="text-ceylon-green-600 text-xs font-semibold uppercase tracking-widest">{featured.category}</span>
            <h2 class="font-serif font-bold text-gray-900 text-2xl lg:text-3xl mt-2 mb-3 group-hover:text-ceylon-green-700 transition-colors text-balance">{featured.title}</h2>
            <p class="text-gray-500 text-sm leading-relaxed line-clamp-3">{featured.excerpt}</p>
            <div class="flex items-center gap-3 mt-5 text-xs text-gray-400">
              <span>{featured.date}</span><span>&bull;</span><span>{featured.readTime} read</span>
            </div>
            <div class="mt-5 inline-flex items-center gap-2 text-ceylon-green-700 font-semibold text-sm">
              Read Article
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </div>
          </div>
        </div>
      </a>

      <!-- Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.map(post => <CardBlog {...post} />)}
      </div>
    </div>
  </section>
</BaseLayout>
