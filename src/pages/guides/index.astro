---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import ExpediaWidget from '../../components/ExpediaWidget.astro';

const guides = [
  {
    href: '/guides/sri-lanka-itinerary-2-weeks',
    image: '/images/scenic-train.webp',
    title: '2-Week Sri Lanka Itinerary',
    category: 'Itineraries',
    description: 'The perfect 14-day route covering ancient ruins, highlands, wildlife and beaches.',
    time: '15 min read',
    icon: '🗺️',
  },
  {
    href: '/guides/sri-lanka-itinerary-1-week',
    image: '/images/sigiriya.webp',
    title: '1-Week Sri Lanka Itinerary',
    category: 'Itineraries',
    description: 'Short on time? This week-long route hits the absolute best of Sri Lanka efficiently.',
    time: '10 min read',
    icon: '⚡',
  },
  {
    href: '/guides/sri-lanka-itinerary-1-month',
    image: '/images/heroes/hero-wildlife.webp',
    title: '1-Month Sri Lanka Itinerary',
    category: 'Itineraries',
    description: 'The ultimate slow-travel route covering every region — north, south, east coast, wildlife parks and hidden corners.',
    time: '18 min read',
    icon: '🌍',
  },
  {
    href: '/guides/best-time-to-visit',
    image: '/images/heroes/hero-hills.webp',
    title: 'Best Time to Visit Sri Lanka',
    category: 'Planning',
    description: 'Month-by-month breakdown of Sri Lanka\'s weather, monsoons and peak seasons.',
    time: '10 min read',
    icon: '📅',
  },
  {
    href: '/guides/sri-lanka-visa-guide',
    image: '/images/negombo.webp',
    title: 'Sri Lanka Visa Guide',
    category: 'Entry & Visas',
    description: 'Everything you need to know about ETA visas, costs and requirements for all nationalities.',
    time: '8 min read',
    icon: '🛂',
  },
  {
    href: '/guides/getting-around-sri-lanka',
    image: '/images/heroes/hero-train.webp',
    title: 'Getting Around Sri Lanka',
    category: 'Transport',
    description: 'Trains, tuk-tuks, buses, drivers — every transport option compared honestly.',
    time: '12 min read',
    icon: '🚂',
  },
  {
    href: '/guides/sri-lanka-budget-guide',
    image: '/images/colombo.webp',
    title: 'Sri Lanka Budget Guide',
    category: 'Costs & Money',
    description: 'Daily costs, tipping culture, exchange rates and how to save money without missing out.',
    time: '9 min read',
    icon: '💰',
  },
  {
    href: '/guides/sri-lanka-safety-guide',
    image: '/images/ella.webp',
    title: 'Sri Lanka Safety Guide',
    category: 'Safety',
    description: 'Is Sri Lanka safe? Everything travellers need to know about staying safe on the island.',
    time: '7 min read',
    icon: '🛡️',
  },
  {
    href: '/guides/sri-lanka-food-guide',
    image: '/images/cooking-classes.webp',
    title: 'Sri Lanka Food Guide',
    category: 'Food & Drink',
    description: 'What to eat, where to eat, and the essential dishes you must try — a complete guide to Sri Lankan cuisine.',
    time: '10 min read',
    icon: '🍛',
  },
  {
    href: '/guides/what-to-pack-sri-lanka',
    image: '/images/horton-plains.webp',
    title: 'What to Pack for Sri Lanka',
    category: 'Planning',
    description: 'The essential packing list — clothing, footwear, health essentials and what to buy locally.',
    time: '8 min read',
    icon: '🎒',
  },
];

const categories = ['All Guides', 'Itineraries', 'Planning', 'Transport', 'Accommodation', 'Safety'];
---

<BaseLayout
  title="Sri Lanka Travel Guides | The Trails of Ceylon"
  description="Expert-written travel guides for Sri Lanka — visa info, itineraries, where to stay, how to get around and everything else you need to plan your trip."
>
  <section class="bg-ceylon-green-900 py-20 relative overflow-hidden">
    <div class="absolute inset-0 opacity-25">
      <img
        src="/images/scenic-train.webp"
        alt=""
        class="w-full h-full object-cover object-center"
        loading="eager"
        width="1920"
        height="600"
      />
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-ceylon-gold-400 text-xs font-semibold uppercase tracking-widest mb-3">Expert Travel Guides</p>
      <h1 class="font-serif font-black text-white text-5xl sm:text-6xl mb-4">Sri Lanka Travel Guides</h1>
      <p class="text-ceylon-green-200 text-lg max-w-2xl mx-auto">
        Everything you need to plan a perfect Sri Lanka trip — from visa info to 2-week itineraries, transport tips to budget guides.
      </p>
    </div>
  </section>

  <!-- Category filter -->
  <section class="bg-white border-b border-gray-100 sticky top-16 lg:top-20 z-40">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-2 overflow-x-auto py-3">
        {categories.map((cat, i) => (
          <button class={`whitespace-nowrap px-4 py-2 rounded-full text-sm font-medium transition-colors ${i === 0 ? 'bg-ceylon-green-700 text-white' : 'text-gray-600 hover:bg-gray-100'}`}>
            {cat}
          </button>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {guides.map(guide => (
          <a href={guide.href} class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1 flex flex-col">
            <div class="relative overflow-hidden aspect-[16/9]">
              <img
                src={guide.image}
                alt={guide.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
                width="400"
                height="225"
                style="object-fit:cover;"
              />
              <span class="absolute top-3 left-3 bg-white/90 backdrop-blur-sm text-gray-700 text-xs font-medium px-2.5 py-1 rounded-full">{guide.category}</span>
            </div>
            <div class="p-5 flex flex-col flex-1">
              <div class="flex items-start gap-3">
                <span class="text-2xl flex-shrink-0">{guide.icon}</span>
                <div>
                  <h2 class="font-serif font-bold text-gray-900 text-base leading-snug group-hover:text-ceylon-green-700 transition-colors">{guide.title}</h2>
                </div>
              </div>
              <p class="text-gray-500 text-sm mt-3 leading-relaxed flex-1">{guide.description}</p>
              <div class="flex items-center justify-between mt-4 pt-4 border-t border-gray-100">
                <span class="text-xs text-gray-400">{guide.time}</span>
                <span class="text-xs font-semibold text-ceylon-green-700 flex items-center gap-1 group-hover:gap-2 transition-all">
                  Read guide
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
  <ExpediaWidget heading="✈️ Plan Your Sri Lanka Trip" />
</BaseLayout>
