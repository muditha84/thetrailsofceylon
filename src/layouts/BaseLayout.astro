---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  image?: string;
  canonicalURL?: string;
  type?: string;
  publishDate?: string;
  author?: string;
}

const {
  title,
  description,
  image = '/images/og-default.jpg',
  canonicalURL = Astro.url.href,
  type = 'website',
  publishDate,
  author = 'The Trails of Ceylon',
} = Astro.props;

const siteURL = 'https://www.thetrailsofceylon.com';
const fullImageURL = image.startsWith('http') ? image : `${siteURL}${image}`;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-H7E27MZJHJ"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-H7E27MZJHJ');
  </script>

  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />

  <!-- Google Search Console verification -->
  <meta name="google-site-verification" content="6Df_jfI-mq3mxAxtbJpO4a2Ctf7D_j4ra_7VLJqnONA" />

  <!-- Primary SEO -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <meta name="robots" content="index, follow" />
  <meta name="author" content={author} />

  <!-- Open Graph -->
  <meta property="og:type" content={type} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={fullImageURL} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:site_name" content="The Trails of Ceylon" />
  <meta property="og:locale" content="en_US" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={fullImageURL} />

  <!-- Article-specific meta -->
  {publishDate && <meta property="article:published_time" content={publishDate} />}
  {type === 'article' && <meta property="article:author" content={author} />}

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;0,900;1,400;1,600&display=swap" rel="stylesheet" />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

  <!-- Sitemap -->
  <link rel="sitemap" href="/sitemap-index.xml" />

  <!-- Smooth scroll -->
  <style>html { scroll-behavior: smooth; }</style>

  <!-- Schema.org JSON-LD: page-level -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": type === 'article' ? 'Article' : 'WebSite',
    "name": title,
    "description": description,
    "url": canonicalURL,
    "publisher": {
      "@type": "Organization",
      "name": "The Trails of Ceylon",
      "url": siteURL,
      "logo": {
        "@type": "ImageObject",
        "url": `${siteURL}/images/logo.svg`
      }
    },
    ...(publishDate && {
      "datePublished": publishDate,
      "author": { "@type": "Person", "name": author }
    })
  })} />
  <!-- Schema.org JSON-LD: TravelAgency -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "TravelAgency",
    "name": "The Trails of Ceylon",
    "description": "Expert travel guides and itineraries for Sri Lanka — destinations, activities, visa info and planning resources.",
    "url": siteURL,
    "logo": {
      "@type": "ImageObject",
      "url": `${siteURL}/images/logo.svg`
    },
    "areaServed": {
      "@type": "Country",
      "name": "Sri Lanka"
    },
    "sameAs": [
      "https://www.instagram.com/thetrailsofceylon",
      "https://www.pinterest.com/thetrailsofceylon",
      "https://www.facebook.com/thetrailsofceylon"
    ]
  })} />
</head>
<body class="min-h-screen flex flex-col">
  <Header />
  <main class="flex-1">
    <slot />
  </main>
  <Footer />

  <!-- ── Cookie Consent Banner ── -->
  <div id="cookie-banner" class="fixed bottom-0 left-0 right-0 z-[9999] bg-ceylon-green-900 text-white shadow-2xl transform translate-y-full transition-transform duration-500" role="dialog" aria-label="Cookie consent">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-4 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-sm text-ceylon-green-100 leading-relaxed">
        We use cookies to enhance your experience and analyse site traffic. By continuing to browse you agree to our
        <a href="/privacy-policy" class="text-ceylon-gold-400 hover:text-ceylon-gold-300 underline">Privacy Policy</a>.
      </p>
      <div class="flex items-center gap-3 flex-shrink-0">
        <button id="cookie-decline" class="text-ceylon-green-300 hover:text-white text-sm font-medium px-4 py-2 rounded-full border border-ceylon-green-600 hover:border-ceylon-green-400 transition-colors">
          Decline
        </button>
        <button id="cookie-accept" class="bg-ceylon-green-500 hover:bg-ceylon-green-400 text-white text-sm font-semibold px-6 py-2 rounded-full transition-colors">
          Accept All
        </button>
      </div>
    </div>
  </div>

  <!-- ── Back to Top Button ── -->
  <button
    id="back-to-top"
    aria-label="Back to top"
    class="fixed bottom-6 right-6 z-50 w-12 h-12 bg-ceylon-green-700 hover:bg-ceylon-green-600 text-white rounded-full shadow-lg flex items-center justify-center opacity-0 pointer-events-none transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-ceylon-green-500"
  >
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18" />
    </svg>
  </button>

  <!-- Expedia Widgets — loaded once, initialises any .eg-widget divs on the page -->
  <script is:inline class="eg-widgets-script" src="https://creator.expediagroup.com/products/widgets/assets/eg-widgets.js"></script>

  <!-- ── Global interactive scripts ── -->
  <script>
    // ── Cookie consent ──
    (function () {
      const banner = document.getElementById('cookie-banner');
      const accept = document.getElementById('cookie-accept');
      const decline = document.getElementById('cookie-decline');
      if (!banner) return;

      const choice = localStorage.getItem('cookie-consent');
      if (!choice) {
        setTimeout(() => banner.classList.replace('translate-y-full', 'translate-y-0'), 600);
      }

      function dismiss() { banner.classList.replace('translate-y-0', 'translate-y-full'); }
      accept?.addEventListener('click', () => { localStorage.setItem('cookie-consent', 'accepted'); dismiss(); });
      decline?.addEventListener('click', () => { localStorage.setItem('cookie-consent', 'declined'); dismiss(); });
    })();

    // ── Back to top ──
    (function () {
      const btn = document.getElementById('back-to-top');
      if (!btn) return;
      function toggle() {
        const show = window.scrollY > 300;
        btn.classList.toggle('opacity-0', !show);
        btn.classList.toggle('pointer-events-none', !show);
      }
      window.addEventListener('scroll', toggle, { passive: true });
      btn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
    })();

    // ── Table of Contents (activates on pages with articles containing H2s) ──
    (function () {
      const article = document.querySelector('article');
      if (!article) return;
      const headings = Array.from(article.querySelectorAll('h2')).filter(h => h.textContent.trim() && h.textContent.trim() !== 'Quick Facts');
      if (headings.length < 2) return;

      headings.forEach((h, i) => {
        if (!h.id) {
          h.id = 'section-' + i + '-' + h.textContent.trim().toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
        }
      });

      const items = headings.map(h =>
        `<li><a href="#${h.id}" class="text-ceylon-green-700 hover:text-ceylon-green-900 hover:underline text-sm transition-colors">${h.textContent.trim()}</a></li>`
      ).join('');

      const toc = document.createElement('div');
      toc.className = 'toc-box not-prose bg-ceylon-green-50 border border-ceylon-green-100 rounded-xl p-5 mb-8';
      toc.innerHTML = `
        <button class="toc-toggle flex items-center justify-between w-full text-left gap-2" aria-expanded="true">
          <span class="font-serif font-bold text-gray-900 text-base">In this article</span>
          <svg class="toc-chevron w-4 h-4 text-gray-400 flex-shrink-0 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <ol class="toc-list mt-3 space-y-1.5 list-decimal list-inside marker:text-ceylon-green-400">${items}</ol>
      `;

      headings[0].insertAdjacentElement('beforebegin', toc);

      const toggle = toc.querySelector('.toc-toggle') as HTMLButtonElement;
      const list = toc.querySelector('.toc-list') as HTMLElement;
      const chevron = toc.querySelector('.toc-chevron') as HTMLElement;
      toggle?.addEventListener('click', () => {
        const open = toggle.getAttribute('aria-expanded') === 'true';
        toggle.setAttribute('aria-expanded', String(!open));
        list.style.display = open ? 'none' : '';
        chevron?.classList.toggle('rotate-180', !open);
      });
    })();

    // ── Share buttons (injected on blog and place pages) ──
    (function () {
      const path = window.location.pathname;
      const isBlogPost = path.startsWith('/blog/') && path !== '/blog/';
      const isPlacePage = path.startsWith('/places/') && path !== '/places/' &&
                          !path.match(/\/(cultural-triangle|hill-country|south-coast|east-coast|north-jaffna|wildlife-parks)\/?$/);
      if (!isBlogPost && !isPlacePage) return;

      const url = encodeURIComponent(window.location.href);
      const pageTitle = encodeURIComponent(document.title);
      const shareData = [
        { name: 'Facebook',  color: '#1877F2', href: `https://www.facebook.com/sharer/sharer.php?u=${url}`, path: 'M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z' },
        { name: 'X / Twitter', color: '#000000', href: `https://twitter.com/intent/tweet?url=${url}&text=${pageTitle}`, path: 'M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.254 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z' },
        { name: 'Pinterest', color: '#E60023', href: `https://pinterest.com/pin/create/button/?url=${url}&description=${pageTitle}`, path: 'M12 0C5.373 0 0 5.372 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z' },
        { name: 'WhatsApp', color: '#25D366', href: `https://wa.me/?text=${pageTitle}%20${url}`, path: 'M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.521.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.521-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z' },
      ];

      function buildShareBar(label: string) {
        const wrap = document.createElement('div');
        wrap.className = 'not-prose flex flex-wrap items-center gap-3 py-5 border-t border-b border-gray-100 my-6';
        wrap.innerHTML = `<span class="text-xs font-semibold text-gray-500 uppercase tracking-widest">${label}</span>`;
        shareData.forEach(s => {
          const a = document.createElement('a');
          a.href = s.href;
          a.target = '_blank';
          a.rel = 'noopener noreferrer';
          a.title = `Share on ${s.name}`;
          a.className = 'inline-flex items-center gap-1.5 text-white text-xs font-semibold px-3 py-1.5 rounded-full transition-opacity hover:opacity-80';
          a.style.backgroundColor = s.color;
          a.innerHTML = `<svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="${s.path}"/></svg>${s.name}`;
          wrap.appendChild(a);
        });
        return wrap;
      }

      // Find the prose container (article or .prose div)
      const article = document.querySelector('article');
      const proseEl = article?.querySelector('.prose, [class*="prose"]') || article;
      if (!proseEl) return;

      // Insert before first h2 (top share)
      const firstH2 = proseEl.querySelector('h2');
      if (firstH2) firstH2.insertAdjacentElement('beforebegin', buildShareBar('Share this:'));

      // Append at end of prose
      proseEl.appendChild(buildShareBar('Share this article:'));
    })();
  </script>
</body>
</html>
